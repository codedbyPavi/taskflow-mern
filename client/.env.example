# Dev: leave empty to use Vite proxy (/api → http://localhost:5000). Avoids CORS on ports 5173+.
# Production: full API origin (no trailing slash)
# VITE_API_URL=https://your-api.example.com
VITE_API_URL=

# Optional: override proxy target in vite.config.js
# VITE_API_PROXY_TARGET=http://localhost:5000
