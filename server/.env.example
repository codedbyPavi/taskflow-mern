MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
JWT_SECRET=your-secret-at-least-32-chars
PORT=5000
CLIENT_URL=http://localhost:5173

# Production (Render): set NODE_ENV=production and disable in-memory fallback
# NODE_ENV=production
# DISABLE_MEMORY_MONGO=true

# Optional: in-memory MongoDB binary version (dev fallback only)
# MONGOMS_VERSION=7.0.14
